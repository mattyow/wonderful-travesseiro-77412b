---
import type { Book } from '../lib/airtable';

interface Props {
  book: Book;
}
const { book } = Astro.props;

const cdnCover = book.coverUrl
  ? `/.netlify/images?url=${encodeURIComponent(book.coverUrl)}&w=240&h=360&fit=cover&q=80`
  : null;
---

<article
  class="book-card"
  role="button"
  tabindex="0"
  data-book-id={book.id}
  data-title={book.title}
  data-author={book.author}
  data-additional-authors={book.additionalAuthors}
  data-isbn={book.isbn}
  data-isbn13={book.isbn13}
  data-tags={book.tags.join(',')}
  data-cover-url={book.coverUrl ?? ''}
>
  <div class="cover-wrap">
    {cdnCover ? (
      <img
        src={cdnCover}
        alt={book.title}
        width="240"
        height="360"
        loading="lazy"
        decoding="async"
        onerror="this.hidden=true;this.nextElementSibling.hidden=false"
      />
    ) : null}
    <div class="placeholder" hidden={!!cdnCover}>
      <span class="ph-title">{book.title}</span>
      <span class="ph-author">{book.author}</span>
    </div>
  </div>
  <div class="meta">
    <p class="book-title">{book.title}</p>
    {book.author && <p class="book-author">{book.author}</p>}
  </div>
</article>

<style>
  .book-card {
    cursor: pointer;
    outline: none;
  }

  .cover-wrap {
    position: relative;
    aspect-ratio: 2 / 3;
    background: #e8e6e0;
    border-radius: 3px;
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .book-card:hover .cover-wrap,
  .book-card:focus-visible .cover-wrap {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .cover-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    gap: 0.5rem;
    background: #e8e6e0;
  }

  .ph-title {
    font-size: 0.8rem;
    font-weight: 500;
    text-align: center;
    color: #555;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ph-author {
    font-size: 0.7rem;
    color: #888;
    text-align: center;
  }

  .meta {
    margin-top: 0.6rem;
  }

  .book-title {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .book-author {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
