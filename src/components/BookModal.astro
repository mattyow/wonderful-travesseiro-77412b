---
---

<dialog id="book-modal" aria-modal="true" aria-label="Book details">
  <div class="modal-inner">
    <button id="modal-close" aria-label="Close">&times;</button>
    <div class="modal-body">
      <div class="modal-cover-wrap">
        <img id="modal-cover" src="" alt="" loading="lazy" decoding="async" hidden />
        <div id="modal-placeholder" class="modal-placeholder" hidden>
          <span class="ph-title"></span>
          <span class="ph-author"></span>
        </div>
      </div>
      <div class="modal-info">
        <h2 id="modal-title"></h2>
        <p id="modal-author" class="modal-author"></p>
        <div class="modal-field" hidden>
          <span class="field-label">Additional contributors</span>
          <span id="modal-additional"></span>
        </div>
        <div class="modal-field">
          <span id="modal-isbn" class="isbn-text"></span>
        </div>
        <div class="modal-field" hidden>
          <span class="field-label">Tags</span>
          <div id="modal-tags" class="modal-tags"></div>
        </div>
      </div>
    </div>
  </div>
</dialog>

<style>
  dialog {
    position: fixed;
    inset: 0;
    margin: auto;
    border: none;
    border-radius: 8px;
    padding: 0;
    background: var(--card-bg, #fff);
    max-width: min(680px, 94vw);
    max-height: 90vh;
    width: 100%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.18);
    overflow: hidden;
  }

  dialog::backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
  }

  .modal-inner {
    position: relative;
    overflow-y: auto;
    max-height: 90vh;
    padding: 2rem;
  }

  #modal-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-muted);
    line-height: 1;
    padding: 0.25rem;
    z-index: 1;
  }

  #modal-close:hover { color: var(--text); }

  .modal-body {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .modal-cover-wrap {
    flex-shrink: 0;
    width: 160px;
  }

  .modal-cover-wrap img {
    width: 100%;
    border-radius: 3px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  .modal-placeholder {
    width: 160px;
    aspect-ratio: 2 / 3;
    background: #e8e6e0;
    border-radius: 3px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    gap: 0.5rem;
  }

  .modal-placeholder .ph-title {
    font-size: 0.8rem;
    font-weight: 500;
    text-align: center;
    color: #555;
    line-height: 1.3;
  }

  .modal-placeholder .ph-author {
    font-size: 0.7rem;
    color: #888;
    text-align: center;
  }

  .modal-info {
    flex: 1;
    min-width: 0;
    padding-top: 0.25rem;
  }

  h2 {
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 0.4rem;
  }

  .modal-author {
    font-size: 0.88rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .modal-field {
    margin-bottom: 0.9rem;
  }

  .field-label {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }

  .isbn-text {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-variant-numeric: tabular-nums;
  }

  .modal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  :global(.tag-chip) {
    background: #eee;
    border-radius: 999px;
    padding: 0.2rem 0.65rem;
    font-size: 0.75rem;
    color: #555;
  }

  @media (max-width: 480px) {
    .modal-body { flex-direction: column; }
    .modal-cover-wrap { width: 120px; }
    .modal-placeholder { width: 120px; }
  }
</style>
