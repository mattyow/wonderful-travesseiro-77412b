---
import { getBooks } from '../lib/airtable';
import Layout from '../layouts/Layout.astro';
import BookCard from '../components/BookCard.astro';
import BookModal from '../components/BookModal.astro';

const { books, hasTags } = await getBooks();

const allTags = hasTags
  ? [...new Set(books.flatMap((b) => b.tags))].sort()
  : [];
---

<Layout title="Books" tagline="Matt Yow's personal library">
  {hasTags && allTags.length > 0 && (
    <div class="filter-bar" id="filter-bar">
      <button class="chip active" data-tag="all">All</button>
      {allTags.map((tag) => (
        <button class="chip" data-tag={tag}>{tag}</button>
      ))}
    </div>
  )}

  <main>
    <div class="grid" id="book-grid">
      {books.map((book) => (
        <BookCard book={book} />
      ))}
    </div>
    {books.length === 0 && (
      <p class="empty">No books found.</p>
    )}
  </main>

  <BookModal />
</Layout>

<script>
  // Filter logic
  const filterBar = document.getElementById('filter-bar');
  if (filterBar) {
    const chips = filterBar.querySelectorAll<HTMLButtonElement>('.chip');
    const cards = document.querySelectorAll<HTMLElement>('.book-card');

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tag!;
        if (tag === 'all') {
          chips.forEach((c) => c.classList.remove('active'));
          chip.classList.add('active');
          cards.forEach((c) => (c.hidden = false));
        } else {
          const allChip = filterBar.querySelector<HTMLButtonElement>('[data-tag="all"]')!;
          allChip.classList.remove('active');
          chip.classList.toggle('active');

          const active = [...chips].filter((c) => c.classList.contains('active') && c.dataset.tag !== 'all').map((c) => c.dataset.tag!);
          if (active.length === 0) {
            allChip.classList.add('active');
            cards.forEach((c) => (c.hidden = false));
          } else {
            cards.forEach((card) => {
              const cardTags = (card.dataset.tags ?? '').split(',').filter(Boolean);
              card.hidden = !active.some((t) => cardTags.includes(t));
            });
          }
        }
      });
    });
  }

  // Modal logic
  const modal = document.getElementById('book-modal') as HTMLDialogElement | null;
  const closeBtn = document.getElementById('modal-close');

  function openModal(bookId: string) {
    const data = document.querySelector<HTMLElement>(`[data-book-id="${bookId}"]`);
    if (!data || !modal) return;

    const title = data.dataset.title ?? '';
    const author = data.dataset.author ?? '';
    const additionalAuthors = data.dataset.additionalAuthors ?? '';
    const isbn = data.dataset.isbn ?? '';
    const isbn13 = data.dataset.isbn13 ?? '';
    const tags = (data.dataset.tags ?? '').split(',').filter(Boolean);
    const coverUrl = data.dataset.coverUrl ?? '';

    const img = modal.querySelector<HTMLImageElement>('#modal-cover');
    const placeholder = modal.querySelector<HTMLElement>('#modal-placeholder');
    const titleEl = modal.querySelector('#modal-title')!;
    const authorEl = modal.querySelector('#modal-author')!;
    const addlEl = modal.querySelector('#modal-additional')!;
    const isbnEl = modal.querySelector('#modal-isbn')!;
    const tagsEl = modal.querySelector('#modal-tags')!;

    titleEl.textContent = title;
    authorEl.textContent = author;

    if (additionalAuthors) {
      addlEl.textContent = additionalAuthors;
      addlEl.parentElement!.hidden = false;
    } else {
      addlEl.parentElement!.hidden = true;
    }

    const isbnParts = [isbn13 && `ISBN-13: ${isbn13}`, isbn && `ISBN-10: ${isbn}`].filter(Boolean);
    isbnEl.textContent = isbnParts.join('  ·  ');

    if (tags.length > 0) {
      tagsEl.innerHTML = tags.map((t) => `<span class="tag-chip">${t}</span>`).join('');
      tagsEl.parentElement!.hidden = false;
    } else {
      tagsEl.parentElement!.hidden = true;
    }

    if (img && placeholder) {
      if (coverUrl) {
        img.src = coverUrl;
        img.alt = title;
        img.hidden = false;
        placeholder.hidden = true;
        img.onerror = () => {
          img.hidden = true;
          placeholder.hidden = false;
          (placeholder.querySelector('.ph-title') as HTMLElement).textContent = title;
          (placeholder.querySelector('.ph-author') as HTMLElement).textContent = author;
        };
      } else {
        img.hidden = true;
        placeholder.hidden = false;
        (placeholder.querySelector('.ph-title') as HTMLElement).textContent = title;
        (placeholder.querySelector('.ph-author') as HTMLElement).textContent = author;
      }
    }

    modal.showModal();
  }

  document.querySelectorAll<HTMLElement>('.book-card').forEach((card) => {
    card.addEventListener('click', () => openModal(card.dataset.bookId!));
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') openModal(card.dataset.bookId!);
    });
  });

  closeBtn?.addEventListener('click', () => modal?.close());

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) modal.close();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') modal?.close();
  });
</script>

<style>
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0 var(--page-pad);
    margin-bottom: 2rem;
  }

  .chip {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    font-size: 0.8rem;
    cursor: pointer;
    color: var(--text-muted);
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .chip:hover,
  .chip.active {
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  main {
    padding: 0 var(--page-pad) 4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem 1.5rem;
  }

  @media (max-width: 1100px) {
    .grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (max-width: 800px) {
    .grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 520px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem 1rem; }
  }

  .empty {
    text-align: center;
    color: var(--text-muted);
    margin-top: 4rem;
  }
</style>
